<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.jade.dreamjournalv2.VaultController">
   <children>
      <TextArea fx:id="dreamInput" layoutX="27.0" layoutY="27.0" AnchorPane.bottomAnchor="300.0" AnchorPane.leftAnchor="27.0" AnchorPane.rightAnchor="380.0" AnchorPane.topAnchor="27.0">
         <font>
            <Font size="18.0" />
         </font>
      </TextArea>
      <VBox layoutX="855.0" layoutY="27.0" prefHeight="297.0" prefWidth="335.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="27.0">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="70.0" prefWidth="284.0">
               <children>
                  <Label prefHeight="44.0" prefWidth="112.0" text="Hours Slept:" textFill="WHITE" />
                  <TextField fx:id="hoursInput" alignment="CENTER" prefHeight="28.0" prefWidth="60.0" />
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" prefHeight="70.0" prefWidth="284.0">
               <children>
                  <Label prefHeight="28.0" prefWidth="172.0" text="Mood Before Bed:" textFill="WHITE" />
                  <ComboBox fx:id="moodBeforeInput" prefHeight="33.0" prefWidth="140.0" />
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" prefHeight="70.0" prefWidth="284.0">
               <children>
                  <Label prefHeight="23.0" prefWidth="172.0" text="Mood Waking Up:" textFill="WHITE" />
                  <ComboBox fx:id="moodAfterInput" prefHeight="33.0" prefWidth="140.0" />
               </children>
            </HBox>
            <CheckBox fx:id="lucidToggle" mnemonicParsing="false" prefHeight="70.0" prefWidth="284.0" text="Lucid Dream" />
         </children>
      </VBox>
      <HBox alignment="CENTER_LEFT" layoutX="27.0" layoutY="519.0" prefHeight="48.0" prefWidth="793.0" AnchorPane.bottomAnchor="233.0" AnchorPane.leftAnchor="27.0" AnchorPane.rightAnchor="380.0">
         <children>
            <Label prefHeight="23.0" prefWidth="150.0" text="Dream Signs: " textFill="WHITE" />
            <TextField fx:id="signsInput" prefHeight="36.0" prefWidth="698.0">
               <font>
                  <Font size="14.0" />
               </font>
            </TextField>
         </children>
      </HBox>
      <HBox alignment="CENTER" layoutX="518.0" layoutY="688.0" prefHeight="57.0" prefWidth="165.0" AnchorPane.bottomAnchor="55.0" AnchorPane.leftAnchor="518.0" AnchorPane.rightAnchor="517.0">
         <children>
            <Button alignment="CENTER" mnemonicParsing="false" onAction="#onSaveClick" prefHeight="53.0" prefWidth="168.0" text="Save Dream" />
         </children>
      </HBox>
   </children>
</AnchorPane>
